# Backend API URL (.NET/C# server)
# Opcional en desarrollo: si no se define, la app usa http://localhost:5065.
# Obligatoria en producción: configurar NEXT_PUBLIC_API_URL explícitamente.
# NEXT_PUBLIC_API_URL=http://localhost:5065

# Sugerencia:
# - usar .env.local para desarrollo
# - usar .env.production para build/start en producción o en una VM

# Next.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# Vercel Analytics (solo en producción)
# VERCEL_ANALYTICS_ID=
